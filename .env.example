# LLM — use Groq and/or OpenAI (Groq is preferred when LLM_PROVIDER=auto)
GROQ_API_KEY=
OPENAI_API_KEY=
# auto | groq | openai
LLM_PROVIDER=auto
# Leave empty for provider defaults. Do NOT set gpt-4o-mini when using Groq — use llama-3.3-70b-versatile or leave blank.
LLM_MODEL=
LLM_TEMPERATURE=0.2

ANTHROPIC_API_KEY=

# Retrieval (Phase 1+)
TAVILY_API_KEY=
PERPLEXITY_API_KEY=

# Optional LangSmith tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# MiniCheck (Phase 2+)
MINICHECK_MODEL_PATH=

# Confidence & pipeline tuning
CONFIDENCE_THRESHOLD_HIGH=8
CONFIDENCE_THRESHOLD_MEDIUM=5
MAX_REFINE_ITERATIONS=2
RETRIEVAL_TOP_K=6
RETRIEVAL_CACHE_TTL_SECONDS=300
RETRIEVAL_MIN_RELEVANCE=0.0
USE_MOCK_WHEN_NO_KEYS=true
